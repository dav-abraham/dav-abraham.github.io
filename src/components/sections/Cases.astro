---
const projects = [
  {
    id: "pinheiros",
    img: "/images/projects/pinheiros-1.png",
    imgInterna: "/images/projects/pinheiros-2.png",
    pt: { 
        titulo: "Cemitério Parque dos Pinheiros", 
        sub: "Design Editorial", 
        texto: "Catálogo institucional focado em comunicação humanizada. Uso de grid modular e respiros para transmitir serenidade num contexto técnico." 
    },
    en: { 
        titulo: "Parque dos Pinheiros Cemetery", 
        sub: "Editorial Design", 
        texto: "Institutional catalog focused on humanized communication. Modular grid and white space used to convey serenity within a technical context." 
    }
  },
  {
    id: "hsse",
    img: "/images/projects/hsse-capa.jpg",
    imgInterna: "/images/projects/hsse-grid.png",
    pt: { 
        titulo: "Campanha QHSE: WFS Brasil", 
        sub: "Design de Informação", 
        texto: "Comunicação técnica para rampa aeroportuária. Transformação de protocolos complexos em peças de alto impacto, garantindo a absorção imediata de fluxos de segurança e prevenção de incidentes." 
    },
    en: { 
        titulo: "HSSE Campaign: WFS Brazil", 
        sub: "Information Design", 
        texto: "Technical communication for airport ramp operations. Streamlining complex safety protocols into high-impact assets to ensure instant absorption of safety workflows and incident prevention." 
    }
  }
];
---

<section id="cases" class="py-12 px-4 md:px-8 max-w-7xl mx-auto w-full">
    <h2 class="text-2xl font-bold mb-8 text-white opacity-80" data-pt="Estudos de Caso" data-en="Case Studies">Estudos de Caso</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 justify-items-center">
        {projects.map(proj => (
            <div class="case-card w-full" onclick={`document.getElementById('modal-${proj.id}').style.display='flex'`}>
                <div class="case-foto" style={`background-image: url('${proj.img}')`}></div>
                <div class="case-info">
                    <h3 class="text-lg font-bold" data-pt={proj.pt.titulo} data-en={proj.en.titulo}>{proj.pt.titulo}</h3>
                    <p class="text-sm text-zinc-400" data-pt={proj.pt.sub} data-en={proj.en.sub}>{proj.pt.sub}</p>
                    <span class="btn-ver" data-pt="Ver Detalhes" data-en="View Details">Ver Detalhes</span>
                </div>
            </div>
        ))}
    </div>

    {projects.map(proj => (
        <div id={`modal-${proj.id}`} class="modal-overlay" onclick="if(event.target == this) this.style.display='none'">
            <div class="modal-content" onclick="event.stopPropagation()">
                <button class="close-btn" onclick={`document.getElementById('modal-${proj.id}').style.display='none'`}>&times;</button>
                <img src={proj.imgInterna} alt="Case Detail" class="modal-img" />
                <div class="modal-text">
                    <h2 class="text-2xl font-bold text-white" data-pt={proj.pt.titulo} data-en={proj.en.titulo}>{proj.pt.titulo}</h2>
                    <p class="mt-4 text-zinc-400 leading-relaxed" data-pt={proj.pt.texto} data-en={proj.en.texto}>{proj.pt.texto}</p>
                </div>
            </div>
        </div>
    ))}
</section>

<style>
    .case-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; overflow: hidden; cursor: pointer; transition: all 0.4s ease; max-width: 500px; }
    .case-card:hover { transform: translateY(-5px); border-color: white; background: rgba(255, 255, 255, 0.08); }
    .case-foto { height: 280px; background-size: cover; background-position: center; }
    .case-info { padding: 1.5rem; color: white; }
    .btn-ver { color: #fff; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 1rem; display: inline-block; border-bottom: 1px solid #444; }
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(15px); }
    .modal-content { background: #0a0a0a; max-width: 900px; width: 100%; max-height: 90vh; overflow-y: auto; border-radius: 24px; position: relative; border: 1px solid rgba(255,255,255,0.1); }
    .modal-img { width: 100%; height: auto; display: block; }
    .modal-text { padding: 2.5rem; color: white; }
    .close-btn { position: absolute; top: 15px; right: 15px; background: #fff; border: none; color: #000; font-size: 1.2rem; width: 35px; height: 35px; border-radius: 50%; cursor: pointer; z-index: 10000; font-weight: bold; }
</style>
