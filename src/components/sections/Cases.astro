---
const casePinheiros = {
    img: "/images/projects/pinheiros-1.png",
    imgInterna: "/images/projects/pinheiros-2.png",
    pt: {
        titulo: "Cemitério Parque dos Pinheiros",
        sub: "Design Editorial",
        texto: "Desenvolvimento de catálogo institucional para um complexo de 330.000m². O foco foi transformar uma comunicação técnica em algo humanizado e sereno. Utilizei um grid modular e respiros generosos para transmitir paz, transformando dados complexos de jazigos em infográficos claros."
    },
    en: {
        titulo: "Parque dos Pinheiros Cemetery",
        sub: "Editorial Design",
        texto: "Development of an institutional catalog for a 330,000m² complex. The focus was to transform technical communication into something humanized and serene. I used a modular grid and generous white space to convey peace, transforming complex burial plot data into clear infographics."
    }
};
---

<section id="cases" class="py-12 px-4 md:px-8 max-w-7xl mx-auto w-full">
    <h2 class="text-2xl font-bold mb-8 text-white opacity-80" 
        data-pt="Estudos de Caso" 
        data-en="Case Studies">
        Estudos de Caso
    </h2>
    
    <div class="case-card" onclick="document.getElementById('modal-pinheiros').style.display='flex'">
        <div class="case-foto" style={`background-image: url('${casePinheiros.img}')`}></div>
        <div class="case-info">
            <h3 class="text-lg font-bold" data-pt={casePinheiros.pt.titulo} data-en={casePinheiros.en.titulo}>
                {casePinheiros.pt.titulo}
            </h3>
            <p class="text-sm text-zinc-400" data-pt={casePinheiros.pt.sub} data-en={casePinheiros.en.sub}>
                {casePinheiros.pt.sub}
            </p>
            <span class="btn-ver" data-pt="Ver Detalhes" data-en="View Details">
                Ver Detalhes
            </span>
        </div>
    </div>

    <div id="modal-pinheiros" class="modal-overlay" onclick="if(event.target == this) this.style.display='none'">
        <div class="modal-content" onclick="event.stopPropagation()">
            <button class="close-btn" onclick="document.getElementById('modal-pinheiros').style.display='none'">&times;</button>
            <img src={casePinheiros.imgInterna} alt="Design Interno" class="modal-img" />
            <div class="modal-text">
                <h2 class="text-2xl font-bold" data-pt={casePinheiros.pt.titulo} data-en={casePinheiros.en.titulo}>
                    {casePinheiros.pt.titulo}
                </h2>
                <p class="mt-4 text-zinc-400 leading-relaxed" data-pt={casePinheiros.pt.texto} data-en={casePinheiros.en.texto}>
                    {casePinheiros.pt.texto}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .case-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.4s ease;
        max-width: 350px;
    }
    .case-card:hover { transform: translateY(-5px); border-color: white; background: rgba(255, 255, 255, 0.08); }
    .case-foto { height: 200px; background-size: cover; background-position: center; }
    .case-info { padding: 1.2rem; color: white; }
    .btn-ver { color: #fff; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 1rem; display: inline-block; border-bottom: 1px solid #444; }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.95);
        z-index: 9999;
        align-items: center; justify-content: center;
        padding: 20px;
        backdrop-filter: blur(15px);
    }
    .modal-content {
        background: #0a0a0a;
        max-width: 800px; width: 100%;
        max-height: 90vh; overflow-y: auto;
        border-radius: 24px;
        position: relative;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .modal-img { width: 100%; height: auto; display: block; }
    .modal-text { padding: 2.5rem; color: white; }
    .close-btn {
        position: absolute; top: 15px; right: 15px;
        background: #fff; border: none; color: #000;
        font-size: 1.2rem; width: 35px; height: 35px; border-radius: 50%;
        cursor: pointer; z-index: 10000; font-weight: bold;
    }
</style>
